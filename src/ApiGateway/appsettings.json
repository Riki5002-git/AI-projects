{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": [
      {
        "RouteId": "orders",
        "ClusterId": "orders",
        "Match": { "Path": "/orders/{**catch-all}" }
      },
      {
        "RouteId": "products",
        "ClusterId": "products",
        "Match": { "Path": "/products/{**catch-all}" }
      },
      {
        "RouteId": "inventory",
        "ClusterId": "inventory",
        "Match": { "Path": "/inventory/{**catch-all}" }
      },
      {
        "RouteId": "notifications",
        "ClusterId": "notifications",
        "Match": { "Path": "/notifications/{**catch-all}" }
      }
    ],
    "Clusters": {
      "orders": {
        "Destinations": {
          "d1": { "Address": "http://orderservice:80/api/orders/" }
        }
      },
      "products": {
        "Destinations": {
          "d1": { "Address": "http://productcatalogservice:80/api/products/" },
          "d2": { "Address": "http://productcatalogservice2:80/api/products/" }
        }
      },
      "inventory": {
        "Destinations": {
          "d1": { "Address": "http://inventoryservice:80/api/inventory/" }
        }
      },
      "notifications": {
        "Destinations": {
          "d1": { "Address": "http://notificationservice:80/api/notifications/" }
        }
      }
    }
  }
}